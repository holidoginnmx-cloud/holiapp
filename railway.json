{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npx prisma@6.19.2 generate --schema=packages/db/schema.prisma"
  },
  "deploy": {
    "startCommand": "npx prisma@6.19.2 migrate deploy --schema=packages/db/schema.prisma && npm --workspace=@holidoginn/api run start",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
