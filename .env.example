DATABASE_URL="postgresql://user:password@localhost:5432/holidoginn?schema=public"
PORT=3000

# Lista de orígenes permitidos por CORS, separados por coma.
# Ejemplo: "https://app.holidoginn.com,https://admin.holidoginn.com"
# En dev, si está vacía, se permite automáticamente localhost y LAN
# (para que Expo Go en el teléfono alcance al API).
ALLOWED_ORIGINS=

# Entorno: "production" cierra el allowlist CORS a solo lo que pongas arriba
# y quita el bypass de rate-limit para localhost.
NODE_ENV=development

# Claves de terceros (no cometer al repo — usa .env local por workspace)
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=   # whsec_... — obtener con `stripe listen` en dev o desde dashboard en prod

# Correo transaccional (Resend)
# RESEND_API_KEY=
# EMAIL_FROM="HolidogInn <hola@holidoginn.com>"
