{
  "expo": {
    "name": "HolidogInn",
    "slug": "holidoginn",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "holidoginn",
    "platforms": [
      "ios",
      "android"
    ],
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.holidoginn.app",
      "buildNumber": "3",
      "deploymentTarget": "13.4",
      "usesAppleSignIn": true,
      "infoPlist": {
        "LSMinimumSystemVersion": "13.4",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "package": "com.holidoginn.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "HolidogInn necesita acceso a tus fotos para subir imágenes de tu mascota y su cartilla de vacunación.",
          "cameraPermission": "HolidogInn necesita acceso a la cámara para tomar fotos de tu mascota y subir su cartilla de vacunación."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.holidoginnmx.app",
          "enableGooglePay": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#3a7cab",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "36f3e249-f177-4247-9e55-f89d017128e8"
      }
    },
    "owner": "holidoginn.mx"
  }
}
