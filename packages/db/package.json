{
  "name": "@holidoginn/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx seed.ts",
    "db:seed:services": "tsx seed-services.ts",
    "db:seed:rooms": "tsx seed-rooms.ts",
    "db:seed:vaccine-catalog": "tsx seed-vaccine-catalog.ts",
    "db:sql:views": "prisma db execute --file ./sql/dashboard_views.sql --schema ./schema.prisma",
    "db:import:legacy": "tsx scripts/import-legacy.ts",
    "db:import:verify": "tsx scripts/import-legacy.ts --verify",
    "db:import:shopify": "tsx scripts/import-shopify.ts",
    "db:import:shopify:verify": "tsx scripts/import-shopify.ts --verify",
    "db:studio": "prisma studio",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1"
  },
  "devDependencies": {
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
