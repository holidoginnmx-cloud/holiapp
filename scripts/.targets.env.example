# Copia este archivo a scripts/.targets.env y rellena con valores reales.
# scripts/.targets.env está en .gitignore — NUNCA lo commitees.
#
# RAILWAY_URL: la URL pública del Postgres de Railway, con credenciales.
# La sacas de:
#   Railway dashboard -> Postgres -> Variables -> DATABASE_PUBLIC_URL
#
# Ejemplo:
# RAILWAY_URL=postgresql://postgres:CHANGEME@roundhouse.proxy.rlwy.net:12345/railway

RAILWAY_URL=
